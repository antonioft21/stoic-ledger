---
import type { Lang } from '../i18n/index';
import { useTranslations } from '../i18n/index';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="product" class="relative pt-20 pb-32 px-6 overflow-hidden">
  <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-16 items-center">
    <div class="lg:col-span-7">
      <h1 class="font-headline font-extrabold text-5xl md:text-7xl text-on-surface leading-[1.1] mb-6 tracking-tight">
        {t.hero.headline1} <br/>
        <span class="text-primary italic">{t.hero.headline2}</span>
      </h1>
      <div class="mb-10 space-y-3">
        <p class="text-on-surface-variant text-xl md:text-2xl max-w-2xl leading-relaxed font-light">
          {t.hero.subheadline}
        </p>
        <p class="text-on-surface font-headline font-semibold text-lg md:text-xl max-w-2xl">
          {t.hero.subheadline2}
        </p>
      </div>
      <div class="flex flex-col sm:flex-row gap-4">
        <a
          href={lang === 'es' ? '/calculator' : '/en/calculator'}
          data-track="cta_click" data-track-label="calculate_real_money"
          class="bg-gradient-to-b from-primary to-primary-dim text-on-primary px-8 py-4 rounded-md font-headline font-bold text-lg shadow-lg hover:-translate-y-px transition-all inline-block text-center"
        >
          {t.hero.ctaPrimary}
        </a>
        <button
          onclick="document.getElementById('waitlist-modal').classList.remove('hidden')"
          data-track="cta_click" data-track-label="join_beta"
          class="bg-secondary-container text-on-secondary-container px-8 py-4 rounded-md font-headline font-bold text-lg hover:bg-surface-variant transition-colors"
        >
          {t.hero.ctaSecondary}
        </button>
      </div>
      <p class="mt-3 text-on-surface-variant text-sm">{t.hero.microCta}</p>
    </div>

    <!-- Visual Mockup -->
    <div class="lg:col-span-5 relative">
      <div class="bg-surface-container-low p-8 rounded-xl shadow-2xl relative z-10">
        <div class="space-y-6">
          <div class="flex justify-between items-center pb-4 border-b border-outline-variant/20">
            <span class="text-on-surface-variant font-label text-sm uppercase tracking-wider">{t.hero.grossBalance}</span>
            <span class="text-on-surface font-headline font-bold text-2xl">€4,800.00</span>
          </div>

          <div class="space-y-3">
            <div class="flex justify-between text-on-surface-variant">
              <div class="flex items-center gap-2">
                <!-- Wallet icon -->
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#9f403d" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 12V22H4a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v2"/><path d="M22 12H16a2 2 0 0 0 0 4h6v-4z"/></svg>
                <span>{t.hero.taxesReserved}</span>
              </div>
              <span class="font-medium">-€1,200.00</span>
            </div>
            <div class="flex justify-between text-on-surface-variant">
              <div class="flex items-center gap-2">
                <!-- Receipt icon -->
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#9f403d" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 2v20l2-1 2 1 2-1 2 1 2-1 2 1 2-1 2 1V2l-2 1-2-1-2 1-2-1-2 1-2-1-2 1z"/><path d="M14 8H8"/><path d="M16 12H8"/><path d="M13 16H8"/></svg>
                <span>{t.hero.expenses}</span>
              </div>
              <span class="font-medium">-€900.00</span>
            </div>
            <div class="flex justify-between text-on-surface-variant">
              <div class="flex items-center gap-2">
                <!-- Calendar icon -->
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#9f403d" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                <span>{t.hero.upcomingPayments}</span>
              </div>
              <span class="font-medium">-€450.00</span>
            </div>
          </div>

          <div class="bg-surface-container-lowest p-8 rounded-lg border-2 border-primary/20 shadow-lg mt-8 text-center ring-4 ring-primary/5">
            <div class="flex flex-col items-center gap-2">
              <span class="text-primary font-headline text-sm uppercase tracking-widest font-extrabold">{t.hero.realMoneyLabel}</span>
              <span class="text-on-primary-container font-headline font-black text-6xl tracking-tighter md:text-7xl">€2,250.00</span>
            </div>
          </div>
        </div>
      </div>

      <p class="text-center text-on-surface-variant font-label italic text-sm mt-6">
        {t.hero.realMoneyCaption}
      </p>

      <!-- Decorative -->
      <div class="absolute -top-10 -right-10 w-64 h-64 bg-primary/5 rounded-full blur-3xl -z-0"></div>
      <div class="absolute -bottom-10 -left-10 w-48 h-48 bg-tertiary/5 rounded-full blur-3xl -z-0"></div>
    </div>
  </div>
</section>
