---
import type { Lang } from '../i18n/index';
import { useTranslations } from '../i18n/index';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="pricing" class="py-32 relative">
  <div class="max-w-5xl mx-auto px-6 text-center">
    <div class="bg-primary px-12 py-20 rounded-2xl relative overflow-hidden">
      <div class="absolute inset-0 opacity-10 pointer-events-none">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-white via-transparent to-transparent"></div>
      </div>
      <h2 class="font-headline font-extrabold text-4xl md:text-5xl text-on-primary mb-6 relative z-10">
        {t.cta.heading}
      </h2>
      <p class="text-primary-container text-xl mb-10 max-w-xl mx-auto relative z-10">
        {t.cta.subheading}
      </p>
      <button
        onclick="document.getElementById('waitlist-modal').classList.remove('hidden')"
        data-track="cta_click" data-track-label="get_early_access"
        class="bg-surface-container-lowest text-primary px-10 py-4 rounded-md font-headline font-bold text-lg hover:scale-105 transition-transform shadow-xl relative z-10"
      >
        {t.cta.button}
      </button>
    </div>
  </div>
</section>
