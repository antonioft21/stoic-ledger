---
import '../styles/global.css';
import Analytics from '@vercel/analytics/astro';

interface Props {
  title: string;
  lang: string;
}

const { title, lang } = Astro.props;
---
<!DOCTYPE html>
<html lang={lang} class="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;600;700;800&family=Inter:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="bg-background text-on-surface font-body selection:bg-primary-container selection:text-on-primary-container">
    <slot />
    <Analytics />
    <script>
      import { track } from '@vercel/analytics';
      document.addEventListener('click', (e) => {
        const btn = (e.target as Element).closest('[data-track]');
        if (!btn) return;
        track(btn.getAttribute('data-track') as string, {
          label: btn.getAttribute('data-track-label') ?? 'unknown',
        });
      });
    </script>
  </body>
</html>
